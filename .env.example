# Base path for a Hive workspace (optional if you run inside the workspace)
HIVE_BASE_PATH=/path/to/hive-workspace

# Optional: project-global observational memory location
# HIVE_GLOBAL_MEMORY_DIR=/path/to/global-memory

# Optional: real-time multi-agent coordination server
# COORDINATOR_URL=http://localhost:8080

# Optional: Weave tracing
# WANDB_API_KEY=your-wandb-api-key
# WEAVE_PROJECT=agent-hive
# WEAVE_DISABLED=false

# Optional: provider-specific credentials for your own evaluators or tools
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
