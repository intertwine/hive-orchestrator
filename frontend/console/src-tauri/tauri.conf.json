{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Hive Command Center",
  "version": "0.1.0",
  "identifier": "com.intertwine.agent-hive",
  "build": {
    "frontendDist": "../dist-desktop",
    "devUrl": "http://127.0.0.1:4175",
    "beforeDevCommand": "pnpm run desktop:dev",
    "beforeBuildCommand": "pnpm run desktop:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Hive Command Center (Beta)",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "agent-hive"
        ]
      }
    }
  }
}
