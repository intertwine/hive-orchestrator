{
  "name": "@agent-hive/opencode-plugin",
  "version": "0.1.0",
  "description": "OpenCode plugin for Agent Hive orchestration integration",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.3.0",
    "glob": "^10.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "peerDependenciesOptional": {
    "@opencode-ai/plugin": true
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "opencode",
    "agent-hive",
    "plugin",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/intertwine/hive-orchestrator"
  }
}
